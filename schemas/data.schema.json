{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/YanlongLai/tw-stocks-daily-report/main/schemas/data.schema.json",
  "$schemaVersion": "1.0.0",
  "title": "TW Stocks Daily Report — Dashboard Data",
  "description": "Aggregate dashboard payload consumed by the DappGo TW Stocks mobile app and web viewer.",
  "type": "object",
  "required": ["last_updated", "tickers", "ticker_data", "sector_rotation"],
  "additionalProperties": true,

  "properties": {
    "last_updated": {
      "type": "string",
      "description": "Date of this snapshot (YYYY-MM-DD)."
    },
    "tickers": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]{4,5}$" }
    },
    "ticker_data": {
      "type": "object",
      "description": "Map of ticker → analysis dict",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "price_change_pct": { "type": "number" },
          "price_history": {
            "type": "array",
            "description": "Last ~250 trading days of OHLCV for chart rendering + client-side MA60/MA200 + timeframe toggles.",
            "items": {
              "type": "object",
              "required": ["date", "close"],
              "properties": {
                "date":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "close":  { "type": "number" },
                "high":   { "type": "number" },
                "low":    { "type": "number" },
                "volume": { "type": "integer" }
              }
            }
          },
          "indicators": {
            "type": "object",
            "properties": {
              "latest_close": { "type": ["number", "null"] },
              "ma_5":   { "type": ["number", "null"] },
              "ma_10":  { "type": ["number", "null"] },
              "ma_20":  { "type": ["number", "null"] },
              "ma_60":  { "type": ["number", "null"] },
              "ma_120": { "type": ["number", "null"] },
              "rsi_14": { "type": ["number", "null"] },
              "macd": {
                "type": "object",
                "properties": {
                  "macd":   { "type": ["number", "null"] },
                  "signal": { "type": ["number", "null"] },
                  "hist":   { "type": ["number", "null"] }
                }
              },
              "kd": {
                "type": "object",
                "properties": {
                  "k": { "type": ["number", "null"] },
                  "d": { "type": ["number", "null"] }
                }
              },
              "bollinger": {
                "type": "object",
                "properties": {
                  "upper":     { "type": ["number", "null"] },
                  "mid":       { "type": ["number", "null"] },
                  "lower":     { "type": ["number", "null"] },
                  "bandwidth": { "type": ["number", "null"] }
                }
              },
              "hv_20":         { "type": ["number", "null"] },
              "volume_today":  { "type": ["number", "null"] },
              "volume_5d_avg": { "type": ["number", "null"] }
            }
          },
          "chip": { "type": "object" },
          "news": {
            "type": "array",
            "description": "Recent FinMind news headlines for this ticker (best-effort, may be empty).",
            "items": {
              "type": "object",
              "properties": {
                "title":   { "type": "string" },
                "url":     { "type": "string" },
                "source":  { "type": "string" },
                "date":    { "type": "string" },
                "summary": { "type": "string" }
              }
            }
          },
          "announcements": {
            "type": "array",
            "description": "TWSE MOPS public announcements for this ticker (best-effort, may be empty).",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "url":   { "type": "string", "format": "uri" },
                "date":  { "type": "string", "format": "date" },
                "type":  { "type": "string" }
              }
            }
          },
          "news_commentary": {
            "type": "string",
            "description": "AI-generated 2-3 sentence Traditional Chinese summary of recent news. Only present when AI generated one."
          },
          "signals": {
            "type": "object",
            "properties": {
              "trend_label":     { "type": "string" },
              "momentum_label":  { "type": "string" },
              "volume_label":    { "type": "string" },
              "chip_label":      { "type": "string" },
              "verdict":         { "type": "string", "enum": ["BUY","HOLD","WATCH","AVOID","SELL"] },
              "verdict_reason":  { "type": "string" }
            }
          },
          "verdict_changed_from": {
            "type": "string",
            "enum": ["BUY","HOLD","WATCH","AVOID","SELL"],
            "description": "Previous day's verdict when it differs from today's. Absent when unchanged."
          },
          "orderbook": {
            "type": "object",
            "description": "Order-book close summary (best-effort, may be {}).",
            "additionalProperties": true
          },
          "chip_streaks": {
            "type": "object",
            "description": "Consecutive buy/sell streaks for institutional players (best-effort, may be {}).",
            "additionalProperties": true
          },
          "holders": {
            "type": "object",
            "description": "Shareholder trend from TWSE quarterly data (best-effort, may be {}).",
            "additionalProperties": true
          },
          "broker_concentration": {
            "type": "object",
            "description": "Top-broker concentration metrics (best-effort, may be {}).",
            "properties": {
              "concentration_pct_5d": { "type": ["number", "null"] },
              "level":                { "type": "string" }
            },
            "additionalProperties": true
          },
          "lending": {
            "type": "object",
            "description": "Securities lending trend (best-effort, may be {}).",
            "additionalProperties": true
          },
          "buyback": {
            "type": "object",
            "description": "Treasury buyback execution progress (best-effort, may be {}).",
            "additionalProperties": true
          },
          "revenue": {
            "type": "object",
            "description": "Monthly revenue YoY metrics (best-effort, may be {}).",
            "additionalProperties": true
          },
          "news_sentiment": {
            "type": "object",
            "description": "Aggregate keyword sentiment across recent news.",
            "properties": {
              "score":               { "type": ["number", "null"] },
              "positive_count":      { "type": "integer" },
              "negative_count":      { "type": "integer" },
              "neutral_count":       { "type": "integer" },
              "label":               { "type": "string" },
              "top_positive_title":  { "type": ["string", "null"] },
              "top_negative_title":  { "type": ["string", "null"] }
            },
            "additionalProperties": true
          },
          "margin_ratio": {
            "type": "object",
            "description": "Margin-to-short ratio metrics from TWSE (best-effort, may be {}).",
            "properties": {
              "margin_balance":            { "type": ["integer", "null"] },
              "short_balance":             { "type": ["integer", "null"] },
              "short_to_margin_ratio_pct": { "type": ["number", "null"] }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "sector_rotation": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tickers":              { "type": "array", "items": { "type": "string" } },
          "avg_change_pct":       { "type": "number" },
          "top_gainer":           { "type": "object" },
          "top_loser":            { "type": "object" },
          "avg_rsi":              { "type": ["number", "null"] },
          "foreign_net_5d_total": { "type": "integer" },
          "verdict":              { "type": "string", "enum": ["HOT","WARM","NEUTRAL","COOL","COLD"] },
          "verdict_reason":       { "type": "string" }
        }
      }
    },
    "sector_correlation": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sector_a":    { "type": "string" },
          "sector_b":    { "type": "string" },
          "correlation": { "type": "number" },
          "direction":   { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Engine-curated buy candidates (low-risk + below MA + momentum-turning). Up to 3.",
      "items": {
        "type": "object",
        "properties": {
          "symbol":       { "type": "string" },
          "name":         { "type": "string" },
          "reason":       { "type": "string" },
          "score":        { "type": "integer" },
          "signals":      { "type": "array", "items": { "type": "string" } },
          "latest_close": { "type": "number" },
          "rsi":          { "type": ["number", "null"] },
          "hv_20":        { "type": ["number", "null"] }
        }
      }
    },
    "cautions": {
      "type": "array",
      "description": "Warning list — verdicts SELL/AVOID, or RSI≥70 with chip distributing. Up to 3.",
      "items": {
        "type": "object",
        "properties": {
          "symbol":       { "type": "string" },
          "name":         { "type": "string" },
          "reason":       { "type": "string" },
          "verdict":      { "type": "string" },
          "signals":      { "type": "array", "items": { "type": "string" } },
          "latest_close": { "type": "number" },
          "rsi":          { "type": ["number", "null"] }
        }
      }
    },
    "market_regime": {
      "type": "object",
      "description": "Top-level market regime classification from TAIEX trend + breadth (may be {} when data unavailable).",
      "properties": {
        "regime":                { "type": "string", "enum": ["risk_on","risk_off","mixed","neutral","unknown"] },
        "taiex_trend":           { "type": "string", "enum": ["up","down","sideways"] },
        "taiex_above_50ma":      { "type": "boolean" },
        "taiex_above_200ma":     { "type": "boolean" },
        "advance_decline_ratio": { "type": ["number", "null"] },
        "breadth_score":         { "type": ["number", "null"] },
        "vol_regime":            { "type": "string", "enum": ["calm","choppy","high"] },
        "sector_dispersion":     { "type": ["number", "null"] },
        "rationale":             { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
